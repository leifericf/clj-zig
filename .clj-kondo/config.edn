;; Teach clj-kondo about clj-zig's defining macros. Each defines its first
;; symbol and carries a boundary signature or field list clj-kondo should
;; not read as ordinary code. defrecordz also interns the record factories,
;; so it gets a hook that recovers their field arity. defspec from
;; test.check defines a test the way deftest does.
{:lint-as
 {clj-zig.core/defnz                              clj-kondo.lint-as/def-catch-all
  clj-zig.core/defz                               clj-kondo.lint-as/def-catch-all
  clj-zig.core/deftypez                           clj-kondo.lint-as/def-catch-all
  clj-zig.core/defenumz                           clj-kondo.lint-as/def-catch-all
  clj-zig.composability-test/defbinaryz           clj-kondo.lint-as/def-catch-all
  clojure.test.check.clojure-test/defspec       clojure.test/deftest}
 :hooks
 {:analyze-call {clj-zig.core/defrecordz hooks.clj-zig/defrecordz}}}
