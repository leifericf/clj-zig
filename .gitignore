# macOS
.DS_Store

# Clojure / tools.deps
/.cpcache/
/target/

# Zig
zig-cache/
zig-out/

# clj-zig artifact cache
/.clj-zig/

# Editor / tooling caches and per-user session state
.clj-kondo/.cache/
.lsp/.cache/
.calva/
.nrepl-port

# agentic-sdk invariant: track only .agentic-sdk/project.edn,
# .agentic-sdk/artifacts/, and the root CLAUDE.md (hand-authored source).
# The .claude/ and .opencode/ adapters and the .agentic-sdk/ masters, spine,
# and state are regenerated by bootstrap-project on each machine.
.claude/
.opencode/
/CLAUDE.md
.agentic-sdk/*
!.agentic-sdk/project.edn
!.agentic-sdk/artifacts/
!.agentic-sdk/artifacts/**
